{
  "name": "vue-starter-lite",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "^24.11.1"
  },
  "scripts": {
    "prepare": "husky || true",
    "dev": "vite --host",
    "preview": "vite preview",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --fix --cache .",
    "lintcss": "stylelint --cache \"src/**/*.{vue,scss,css}\"",
    "lintcss:fix": "stylelint --cache --fix \"src/**/*.{vue,scss,css}\"",
    "typecheck": "vue-tsc --build",
    "check": "run-p lint lintcss typecheck",
    "build": "run-s check build:force",
    "build:force": "vite build"
  },
  "lint-staged": {
    "*.{css,scss}": "stylelint --fix",
    "*.{ts,js,json,html}": "eslint --fix",
    "*.vue": [
      "eslint --fix",
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "@nuxt/ui": "^4.5.1",
    "ky": "^2.0.2",
    "nanoid": "^5.1.9",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "valibot": "^1.3.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@html-eslint/eslint-plugin": "^0.58.1",
    "@html-eslint/parser": "^0.58.1",
    "@iconify/vue": "^5.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-config": "^5.0.0",
    "@stylistic/stylelint-plugin": "^5.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass-embedded": "^1.98.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-scss": "^7.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.5"
  }
}
